# Database connection string
DATABASE_URL=
# JWT secret for access tokens
JWT_SECRET=
# JWT secret for refresh tokens
JWT_REFRESH_SECRET=
# Port for the server
PORT=3000
# Node environment (development/production)
NODE_ENV=development
# Allowed CORS origin
CORS_ORIGIN=http://localhost:5173
# Bcrypt hashing rounds
BCRYPT_ROUNDS=12
